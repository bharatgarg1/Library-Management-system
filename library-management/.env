FLASK_ENV=development
SECRET_KEY=my-super-secret-key-change-this
DATABASE_URL=sqlite:///library_dev.db
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
